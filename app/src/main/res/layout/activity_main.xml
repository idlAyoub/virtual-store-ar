<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:orientation="vertical"
    tools:context=".ui.MainActivity">

    <!-- ── HEADER ──────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp"
        android:background="@color/color_background">

        <!-- Title block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VirtualStore"
                android:textColor="@color/color_text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_add_cart_button" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="AR enabled"
                    android:textColor="@color/color_primary"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Cart button -->
        <FrameLayout
            android:id="@+id/cartIconContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_header_button"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cart"
                android:contentDescription="Cart"
                app:tint="@color/color_text_primary" />

            <TextView
                android:id="@+id/tvCartBadge"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/badge_background_round"
                android:text="0"
                android:textColor="@color/color_on_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <!-- ── SEARCH ──────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:background="@color/color_background">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:hint="Search products..."
            android:background="@drawable/bg_search_bar"
            android:textColor="@color/color_text_primary"
            android:textColorHint="@color/color_text_tertiary"
            android:textSize="14sp"
            android:drawableStart="@drawable/ic_filter"
            android:drawablePadding="12dp"
            android:inputType="text"
            android:maxLines="1" />

    </LinearLayout>

    <!-- Slim divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider" />

    <!-- ── PRODUCT GRID ──────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/color_background"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2" />

</LinearLayout>
