<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:orientation="vertical"
    tools:context=".ui.MainActivity">

    <!-- HEADER SECTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_screen"
        android:paddingVertical="16dp"
        android:background="@color/color_card"
        android:elevation="2dp">

        <!-- App Title Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- App Title: VirtualStore -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VirtualStore"
                android:textColor="@color/color_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <!-- Subtitle: Smart Shopping AR -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Smart Shopping AR"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Cart Icon with Badge -->
        <FrameLayout
            android:id="@+id/cartIconContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cart"
                android:contentDescription="Cart"
                app:tint="@color/color_primary" />

            <!-- Cart Badge showing number of items -->
            <TextView
                android:id="@+id/tvCartBadge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/badge_background_round"
                android:text="0"
                android:textColor="@color/color_white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <!-- SEARCH AND FILTER SECTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/color_card"
        android:elevation="1dp">

        <!-- Search Bar Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_screen"
            android:paddingTop="4dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <!-- Rounded Search Bar -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:hint="Rechercher un produit..."
                android:background="@drawable/bg_search_bar"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_tertiary"
                android:textSize="14sp"
                android:drawableStart="@drawable/ic_filter"
                android:drawablePadding="12dp"
                android:inputType="text"
                android:maxLines="1" />

        </LinearLayout>

        <!-- Category Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingBottom="12dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/chipContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_screen"
                android:gravity="center_vertical">

                <!-- Chips are added programmatically -->

            </LinearLayout>

        </HorizontalScrollView>

    </LinearLayout>


    <!-- PRODUCT GRID (2 COLUMNS) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/color_background"
        android:clipToPadding="false"
        android:padding="10dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2" />

</LinearLayout>
