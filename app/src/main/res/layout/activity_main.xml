<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- MODERN TOP NAVIGATION BAR -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:background="@color/color_card"
            android:elevation="4dp"
            android:translationZ="4dp">

            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menu"
                app:tint="@color/color_text_primary"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- DYNAMIC MIDDLE SECTION: TITLE ↔ SEARCH -->
            <FrameLayout
                android:id="@+id/middleSection"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp">

                <TextView
                    android:id="@+id/tvAppTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="Virtual Store"
                    android:textColor="@color/color_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.01" />

                <LinearLayout
                    android:id="@+id/searchContainer"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center_vertical|end"
                    android:background="@drawable/bg_search_bar"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:visibility="gone"
                    android:alpha="0">

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Rechercher..."
                        android:textColor="@color/color_text_primary"
                        android:textColorHint="@color/color_text_tertiary"
                        android:textSize="14sp"
                        android:inputType="text"
                        android:maxLines="1"
                        android:imeOptions="actionSearch" />
                </LinearLayout>

            </FrameLayout>

            <ImageView
                android:id="@+id/ivSearchIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_search"
                android:contentDescription="Search"
                app:tint="@color/color_text_primary"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/ivFavorite"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_heart"
                android:contentDescription="Favorites"
                app:tint="@color/color_text_primary"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <FrameLayout
                android:id="@+id/cartIconContainer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_cart"
                    android:contentDescription="Cart"
                    app:tint="@color/color_text_primary" />

                <TextView
                    android:id="@+id/tvCartBadge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/badge_background_round"
                    android:text="0"
                    android:textColor="@color/color_white"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

        <!-- CATEGORY FILTER CHIPS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="@color/color_card"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/chipContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_screen"
                android:gravity="center_vertical">
                <!-- Chips are added programmatically -->
            </LinearLayout>

        </HorizontalScrollView>


        <!-- PRODUCT GRID & EMPTY STATE -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProducts"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/color_background"
                android:clipToPadding="false"
                android:padding="10dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2" />

            <!-- EMPTY STATE SEARCH -->
            <LinearLayout
                android:id="@+id/emptyStateSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_search_off"
                    app:tint="@color/color_text_tertiary"
                    android:alpha="0.5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aucun résultat trouvé"
                    android:textColor="@color/color_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Essayez de rechercher autre chose"
                    android:textColor="@color/color_text_tertiary"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- SIDE DRAWER NAVIGATION -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/color_white"
        app:itemTextColor="@color/color_text_primary"
        app:itemIconTint="@color/color_primary"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
