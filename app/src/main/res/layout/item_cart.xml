<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/color_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/color_stroke_accent"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top row: image + info + delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/color_surface_elevated">

                <ImageView
                    android:id="@+id/ivProductImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    tools:src="@color/color_secondary_bg" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProductName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/color_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.1"
                    tools:text="iPhone 12 Pro" />

                <TextView
                    android:id="@+id/tvUnitPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp"
                    tools:text="$999.00 each" />

                <TextView
                    android:id="@+id/tvItemSubtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/color_accent_gold"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="$1,998.00" />

            </LinearLayout>

            <!-- Delete -->
            <ImageButton
                android:id="@+id/btnRemoveItem"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Remove item"
                android:src="@drawable/ic_delete"
                app:tint="@color/color_text_tertiary" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="12dp"
            android:background="@color/color_divider" />

        <!-- Bottom: stock + quantity stepper -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvStockNote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp"
                tools:text="In Stock" />

            <!-- Quantity stepper -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:background="@drawable/stepper_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp">

                <ImageButton
                    android:id="@+id/btnDecreaseQuantity"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Decrease"
                    android:src="@drawable/ic_minus"
                    app:tint="@color/color_text_primary" />

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/color_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="2" />

                <ImageButton
                    android:id="@+id/btnIncreaseQuantity"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Increase"
                    android:src="@drawable/ic_plus"
                    app:tint="@color/color_primary" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>