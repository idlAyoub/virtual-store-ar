<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_card"
    android:fillViewport="true"
    tools:context=".ui.OrderSummaryActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_screen">

        <!-- Success Circle -->
        <FrameLayout
            android:layout_width="@dimen/success_circle_size"
            android:layout_height="@dimen/success_circle_size">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/success_circle_background" />

            <ImageView
                android:layout_width="@dimen/checkmark_size"
                android:layout_height="@dimen/checkmark_size"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                app:tint="@color/color_white" />

        </FrameLayout>

        <!-- Order Confirmed Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/order_confirmed"
            android:textColor="@color/color_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Thank You Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/thank_you"
            android:textColor="@color/color_text_secondary"
            android:textSize="14sp" />

        <!-- Order Details Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/color_card"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_card">

                <!-- Item Total -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/summary_row_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/item_total"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvItemTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Tax -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/summary_row_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/tax"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvTax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$5.00"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Discount -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/summary_row_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/discount"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvDiscount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="@color/color_border" />

                <!-- Total -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/summary_row_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/total"
                        android:textColor="@color/color_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textColor="@color/color_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Continue Shopping Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinueShopping"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_primary"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/color_primary"
            android:text="@string/continue_shopping"
            android:textColor="@color/color_white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="@dimen/radius_pill" />

        <!-- View Order Details Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewOrderDetails"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_secondary"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/color_card"
            android:strokeColor="@color/color_black"
            android:strokeWidth="1"
            android:text="@string/view_order_details"
            android:textColor="@color/color_text_primary"
            android:textSize="16sp"
            app:cornerRadius="@dimen/radius_pill" />

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>

</ScrollView>