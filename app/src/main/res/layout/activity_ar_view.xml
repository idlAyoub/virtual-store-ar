<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- AR Camera Surface -->
    <io.github.sceneview.ar.ARSceneView
        android:id="@+id/arSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── TOP BAR (slim glassmorphic) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="top"
        android:background="@color/color_semi_transparent_dark"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <!-- Close -->
        <FrameLayout
            android:id="@+id/btnCloseAR"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_header_button"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                android:contentDescription="Close AR"
                app:tint="@color/color_white" />

        </FrameLayout>

        <!-- Product Name -->
        <TextView
            android:id="@+id/tvARProductName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="12dp"
            android:text="Product"
            android:textColor="@color/color_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

        <!-- Status icon -->
        <ImageView
            android:id="@+id/ivModelStatus"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check"
            android:contentDescription="Status"
            app:tint="@color/color_primary"
            android:visibility="invisible" />

    </LinearLayout>

    <!-- ── TRACKING STATUS chip (center bottom-ish) ── -->
    <TextView
        android:id="@+id/tvTrackingStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="220dp"
        android:background="@drawable/badge_background"
        android:paddingHorizontal="18dp"
        android:paddingVertical="9dp"
        android:text="@string/searching_surfaces"
        android:textColor="@color/color_white"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- ── LOADING OVERLAY ── -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_camera_overlay"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:indeterminateTint="@color/color_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/loading_model"
            android:textColor="@color/color_white"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ── BOTTOM CONTROL PANEL ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/color_semi_transparent_dark"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        android:visibility="gone"
        android:id="@+id/layoutControlPanel">

        <!-- Gesture hints row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_drag" android:contentDescription="@string/move" app:tint="@color/color_text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/move" android:textColor="@color/color_text_secondary" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_scale" android:contentDescription="@string/pinch_scale" app:tint="@color/color_text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/pinch_scale" android:textColor="@color/color_text_secondary" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_camera" android:contentDescription="@string/rotate" app:tint="@color/color_text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/rotate" android:textColor="@color/color_text_secondary" android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Scale buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScaleDown"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/scale_minus"
                android:textSize="13sp"
                android:backgroundTint="@color/color_surface_elevated"
                android:textColor="@color/color_text_primary"
                app:cornerRadius="23dp"
                app:strokeColor="@color/color_stroke_accent"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScaleUp"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/scale_plus"
                android:textSize="13sp"
                android:backgroundTint="@color/color_surface_elevated"
                android:textColor="@color/color_text_primary"
                app:cornerRadius="23dp"
                app:strokeColor="@color/color_stroke_accent"
                app:strokeWidth="1dp" />

        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetModel"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/reset"
                android:textSize="14sp"
                android:backgroundTint="@color/color_surface_elevated"
                android:textColor="@color/color_text_primary"
                app:cornerRadius="25dp"
                app:strokeColor="@color/color_stroke_accent"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCart"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="2"
                android:layout_marginStart="8dp"
                android:text="@string/add_to_cart"
                android:textSize="14sp"
                android:backgroundTint="@color/color_primary"
                android:textColor="@color/color_on_primary"
                android:textStyle="bold"
                app:cornerRadius="25dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Error/Status toast -->
    <FrameLayout
        android:id="@+id/layoutErrorMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="68dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/color_semi_transparent_dark"
            android:padding="12dp"
            android:layout_marginHorizontal="16dp">

            <ImageView
                android:id="@+id/ivErrorIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_check"
                android:contentDescription="Status"
                app:tint="@color/color_primary" />

            <TextView
                android:id="@+id/tvErrorMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Status"
                android:textColor="@color/color_white"
                android:textSize="13sp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
