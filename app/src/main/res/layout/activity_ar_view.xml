<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ARSceneView - Main AR rendering surface -->
    <io.github.sceneview.ar.ARSceneView
        android:id="@+id/arSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Header Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="@android:color/black"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <!-- Close Button -->
        <FrameLayout
            android:id="@+id/btnCloseAR"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                android:contentDescription="Close AR"
                app:tint="@color/color_white" />

        </FrameLayout>

        <!-- Product Name -->
        <TextView
            android:id="@+id/tvARProductName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Product"
            android:textColor="@color/color_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Model Status Icon -->
        <ImageView
            android:id="@+id/ivModelStatus"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_ar"
            android:contentDescription="Model Status"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Center: Placement Instructions -->
    <LinearLayout
        android:id="@+id/layoutPlacementGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@drawable/bg_ar_badge"
        android:visibility="visible">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_ar"
            android:contentDescription="Find Surface" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Looking for surfaces..."
            android:textColor="@color/color_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Move your device around to detect surfaces, then tap to place the product"
            android:textColor="@color/color_white"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:alpha="0.8" />

    </LinearLayout>

    <!-- Bottom: Tracking Status Bar -->
    <LinearLayout
        android:id="@+id/layoutTrackingStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="100dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="@color/color_semi_transparent_dark"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check"
            android:contentDescription="Tracking"
            app:tint="@color/color_primary" />

        <TextView
            android:id="@+id/tvTrackingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Tracking active"
            android:textColor="@color/color_white"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Bottom: Control Panel -->
    <LinearLayout
        android:id="@+id/layoutControlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:background="@color/color_semi_transparent_dark"
        android:visibility="gone">

        <!-- Gesture Hints -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="48dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_filter"
                    android:contentDescription="Drag"
                    app:tint="@color/color_white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Drag to Move"
                    android:textColor="@color/color_white"
                    android:textSize="11sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="48dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_plus"
                    android:contentDescription="Pinch"
                    app:tint="@color/color_white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Pinch to Scale"
                    android:textColor="@color/color_white"
                    android:textSize="11sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_ar"
                    android:contentDescription="Rotate" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Rotate"
                    android:textColor="@color/color_white"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Scale Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScaleDown"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Scale −"
                android:textSize="13sp"
                android:backgroundTint="@color/color_semi_transparent_dark"
                android:textColor="@color/color_white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScaleUp"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Scale +"
                android:textSize="13sp"
                android:backgroundTint="@color/color_semi_transparent_dark"
                android:textColor="@color/color_white" />

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetModel"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Reset"
                android:textSize="13sp"
                android:backgroundTint="@color/color_text_secondary"
                android:textColor="@android:color/black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCart"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Add to Cart"
                android:textSize="13sp"
                android:backgroundTint="@color/color_primary"
                android:textColor="@color/color_white" />

        </LinearLayout>

    </LinearLayout>


    <!-- Error/Status Toast Container -->
    <FrameLayout
        android:id="@+id/layoutErrorMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="60dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/color_semi_transparent_dark"
            android:padding="12dp"
            android:layout_marginHorizontal="16dp">

            <ImageView
                android:id="@+id/ivErrorIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check"
                android:contentDescription="Status"
                app:tint="@color/color_primary" />

            <TextView
                android:id="@+id/tvErrorMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Status message"
                android:textColor="@color/color_white"
                android:textSize="13sp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>