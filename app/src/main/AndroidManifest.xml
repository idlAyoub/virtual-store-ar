<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet access (Glide loading from URLs) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Network state monitoring -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Required for ARCore / ARSceneView -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">

        <!-- ARCore Optional Metadata -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="optional" />

        <!-- Launcher -->
        <activity
            android:name="com.example.myapplication.ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Product Detail -->
        <activity
            android:name="com.example.myapplication.ui.ProductDetailActivity"
            android:exported="false"
            android:parentActivityName="com.example.myapplication.ui.MainActivity" />

        <!-- AR View -->
        <activity
            android:name="com.example.myapplication.ui.ARViewActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Order Summary -->
        <activity
            android:name="com.example.myapplication.ui.OrderSummaryActivity"
            android:exported="false" />

        <!-- Cart Activity -->
        <activity
            android:name="com.example.myapplication.ui.CartActivity"
            android:exported="false" />

    </application>

</manifest>